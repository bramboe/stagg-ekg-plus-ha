{
  "domain": "fellow_stagg",
  "name": "Fellow Stagg EKG Pro (HTTP CLI)",
  "codeowners": ["@bramboe"],
  "config_flow": true,
  "dependencies": ["bluetooth", "bluetooth_adapters", "frontend", "http", "persistent_notification"],
  "documentation": "https://github.com/bramboe/stagg-ekg-plus-ha",
  "iot_class": "local_polling",
  "issue_tracker": "https://github.com/bramboe/stagg-ekg-plus-ha/issues",
  "requirements": ["bleak-retry-connector>=4.0.0"],
  "version": "0.3.30",
  "zeroconf": ["_http._tcp.local."],
  "bluetooth": [
    { "local_name": "Stagg*" },
    { "local_name": "EKG*" },
    { "local_name": "Fellow*" },
    { "service_uuid": "021a9004-0382-4aea-bff4-6b3f1c5adfb4" },
    { "local_name": "Stagg*", "connectable": false },
    { "local_name": "EKG*", "connectable": false },
    { "local_name": "Fellow*", "connectable": false },
    { "service_uuid": "021a9004-0382-4aea-bff4-6b3f1c5adfb4", "connectable": false }
  ],
  "loggers": ["custom_components.fellow_stagg"]
}
